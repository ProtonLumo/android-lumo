#!/usr/bin/env bash

# Ensure we use Java 17 (required by the project)
export JAVA_HOME=$(/usr/libexec/java_home -v 17)

echo "Running detekt check..."
OUTPUT="/tmp/detekt-$(date +%s)"
./gradlew detekt --no-daemon --no-configuration-cache > "$OUTPUT" 2>&1
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  cat "$OUTPUT"
  rm "$OUTPUT"
  echo "***********************************************"
  echo "                 detekt failed                 "
  echo " Please fix the above issues before committing "
  echo "***********************************************"
  exit $EXIT_CODE
fi
rm "$OUTPUT"
